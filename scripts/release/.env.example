# リリーススクリプト用 環境変数設定ファイル
#
# 使い方:
#   cp .env.example .env
#   # .env に実際の値を記入
#
# 各スクリプト実行時に load_env.sh 経由で自動読み込みされます。
# .env は Git にコミットしないでください。

# =============================================================================
# iOS — App Store Connect（TestFlight アップロード）
# 使用スクリプト: ios/upload_testflight.sh
# =============================================================================

# 方法1: App Store Connect API Key（推奨）
# https://appstoreconnect.apple.com/access/api で作成
APP_STORE_API_KEY_ID=
APP_STORE_API_ISSUER_ID=
APP_STORE_API_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8

# 方法2: Apple ID + App-specific password（API Key 未設定時のフォールバック）
# App-specific password: https://appleid.apple.com/account/manage
APPLE_ID=
APP_SPECIFIC_PASSWORD=

# =============================================================================
# iOS — ビルド（AdMob）
# 使用スクリプト: ios/ios_upload_build.sh
# =============================================================================

ADMOB_IOS_BANNER_HOME_ID=
ADMOB_IOS_INTERSTITIAL_RESULT_ID=

# =============================================================================
# Android — Google Play アップロード
# 使用スクリプト: android/android_upload_internal_test.sh
# =============================================================================

ANDROID_PACKAGE_NAME=com.example.app
GOOGLE_PLAY_JSON_KEY_PATH=/path/to/google-play-service-account.json

# 配布トラック: internal / alpha / beta / production など
ANDROID_PLAY_TRACK=internal

# リリース状態: draft（初回・ドラフト時） / completed（リリース済みアプリ）
RELEASE_STATUS=draft
